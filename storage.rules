rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /pdfs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /materials/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /sermons/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
