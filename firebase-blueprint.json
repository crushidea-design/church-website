{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the church website.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A post in the Research Lab or Community.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["research", "community", "sermon", "journal"] },
        "subCategory": { "type": "string", "enum": ["worship", "preaching", "pastoring", "governing", "general", "past_sermons", "pilgrims_progress"] },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "commentCount": { "type": "number" },
        "pdfUrl": { "type": "string" },
        "pdfName": { "type": "string" }
      },
      "required": ["title", "content", "category", "authorId", "authorName", "createdAt", "updatedAt", "commentCount"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "content", "authorId", "authorName", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact message from a visitor.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "heroImageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["heroImageUrl", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores research articles and community posts."
    },
    "comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments on posts."
    },
    "contacts/{contactId}": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Stores contact messages."
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Stores global application settings."
    }
  }
}
