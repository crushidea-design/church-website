                  <Link to={`/post/${post.id}`} className="p-8 flex-grow flex flex-col">
                    <h3 className="text-xl font-bold text-wood-900 mb-4 line-clamp-2 leading-tight group-hover:text-wood-700 transition-colors">
                      {post.title}
                    </h3>
