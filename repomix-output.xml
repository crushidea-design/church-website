                    <div className="flex items-center text-sm text-wood-500 gap-4">
                      <span className="flex items-center gap-1">
                        <Calendar className="w-4 h-4" />
                        {comment.createdAt?.toLocaleDateString()}
                      </span>
                      <span className="text-wood-400">
                        원문 보기 &rarr;
